{
  "expo": {
    "name": "Bazilika sv. Jakuba",
    "slug": "bazilika-sv-jakuba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-splash.jpg",
    "scheme": "bazilika",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bazilika.jakuba"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-splash.jpg",
        "backgroundColor": "#1a3d3d"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bazilika.jakuba"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-splash.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-splash.jpg",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#1a3d3d"
        }
      ],
      "expo-font",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
